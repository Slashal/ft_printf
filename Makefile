CC = cc
CFLAGS = -Wall -Wextra -Werror
RM = rm -rf
NAME = libftprintf.a

PRINT_SRCS = ft_all_putnbr.c ft_printf.c ft_utils.c ft_utils2.c

LIBFTDIR = Libft
LIBFT = $(LIBFTDIR)/libft.a

PRINT_OBJS = $(PRINT_SRCS:.c=.o)

all: $(LIBFT) $(NAME)

$(LIBFT):
	$(MAKE) -C $(LIBFTDIR)

$(NAME): $(PRINT_OBJS) $(LIBFT)
	cp $(LIBFT) $(NAME)
	ar rc $(NAME) $(PRINT_OBJS)
